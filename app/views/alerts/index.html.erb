<% content_for :title, "alert" %>

<canvas
    id="flow-canvas"
    class="flow-canvas"
    data-controller="flow"
    aria-hidden="true"
></canvas>

<a href="/" class="logo-container" aria-label="@everyone home">
    <%= image_tag "logo-with-text.png", alt: "@everyone logo", class: "logo logo--studio" %>
</a>

<main class="studio-page alert-page">
    <section class="studio-top">
        <h1>Live Alert</h1>
        <p>Trigger calls and watch who is being called, who hung up, and who accepted.</p>
    </section>

    <section
        class="studio-table-shell alert-shell"
        data-controller="alert"
        data-alert-db-contacts="<%= json_escape(@db_confirmed_contacts.to_json) %>"
    >
        <div class="alert-intake" data-alert-target="intakeCard" hidden>
            <div class="alert-intake__head">
                <p class="alert-intake__eyebrow">Before we call</p>
                <p class="alert-intake__progress" data-alert-target="intakeProgress"></p>
            </div>
            <h2 data-alert-target="intakeTitle">How are you feeling right now?</h2>
            <p class="alert-intake__hint" data-alert-target="intakeHint">
                Choose the option that is closest. You can skip this and call immediately.
            </p>
            <div class="alert-intake__options" data-alert-target="intakeOptions"></div>
            <div class="alert-intake__actions">
                <button
                    type="button"
                    class="studio-action-btn"
                    data-action="click->alert#skipPrompts"
                >
                    Skip prompts
                </button>
            </div>
        </div>

        <div class="alert-controls">
            <button
                type="button"
                class="studio-alert-chip is-primary alert-trigger"
                data-alert-target="alertButton"
                data-db-count="<%= @callable_contact_count %>"
                data-action="click->alert#startAlert"
            >
                Call <%= @callable_contact_count %> contact<%= "s" unless @callable_contact_count == 1 %>
            </button>
            <button
                type="button"
                class="studio-alert-chip alert-cancel"
                data-alert-target="cancelButton"
                data-action="click->alert#cancelAlert"
                disabled
            >
                Cancel
            </button>
            <button type="button" class="studio-alert-chip">
                Emergency Contacts
            </button>
            <a href="/studio" class="studio-alert-chip">
                Manage Contacts
            </a>
        </div>

        <div class="alert-meta">
            <div class="alert-stage" data-alert-target="stage">
                <article class="alert-zone">
                    <h3>
                        Calling
                        <span data-alert-target="callingCount">0</span>
                    </h3>
                    <div class="alert-zone-icons" data-alert-target="callingZone"></div>
                </article>
                <article class="alert-zone">
                    <h3>
                        Declined
                        <span data-alert-target="declinedCount">0</span>
                    </h3>
                    <div class="alert-zone-icons" data-alert-target="declinedZone"></div>
                </article>
                <article class="alert-zone">
                    <h3>
                        No Response
                        <span data-alert-target="noResponseCount">0</span>
                    </h3>
                    <div class="alert-zone-icons" data-alert-target="noResponseZone"></div>
                </article>
                <article class="alert-zone">
                    <h3>
                        Accepted
                        <span data-alert-target="acceptedCount">0</span>
                    </h3>
                    <div class="alert-zone-icons" data-alert-target="acceptedZone"></div>
                </article>
                <div class="alert-icons-layer" data-alert-target="iconLayer" aria-hidden="true"></div>
            </div>
            <p class="alert-error" data-alert-target="error"></p>
        </div>

        <div class="studio-table-wrap">
            <table class="studio-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Live status</th>
                    </tr>
                </thead>
                <tbody data-alert-target="tbody"></tbody>
            </table>
        </div>
    </section>

    <section class="studio-table-shell alert-help-card">
        <%
            crisis_support = [
                {
                    title: "Samaritans",
                    subtitle: "24/7 listening support",
                    links: [
                        { label: "Call 116 123", href: "tel:116123" },
                        { label: "Website", href: "https://www.samaritans.org/samaritans-ireland/about/governance-and-structure/contact-us/" }
                    ]
                },
                {
                    title: "Pieta",
                    subtitle: "24/7 suicide and self-harm crisis support",
                    links: [
                        { label: "Call 1800 247 247", href: "tel:1800247247" },
                        { label: "Text HELP to 51444", href: "sms:51444" },
                        { label: "Helpline", href: "https://www.pieta.ie/how-we-can-help/helpline/" }
                    ]
                },
                {
                    title: "Text About It / spunout",
                    subtitle: "24/7 text support",
                    links: [
                        { label: "Text TALK to 50808", href: "sms:50808" },
                        { label: "Website", href: "https://www.textaboutit.ie/" }
                    ]
                },
                {
                    title: "HSE Information Line",
                    subtitle: "24/7 information and signposting",
                    links: [
                        { label: "Call 1800 111 888", href: "tel:1800111888" },
                        { label: "Service info", href: "https://www2.hse.ie/mental-health/services-support/your-mental-health-information-line/" }
                    ]
                }
            ]

            non_emergency_support = [
                {
                    title: "Aware",
                    subtitle: "Depression and bipolar support line (daily 10am-10pm)",
                    links: [
                        { label: "Call 1800 80 48 48", href: "tel:1800804848" },
                        { label: "Website", href: "https://www.aware.ie/" }
                    ]
                },
                {
                    title: "Childline",
                    subtitle: "Under 18s support, available 24/7",
                    links: [
                        { label: "Call 1800 66 66 66", href: "tel:1800666666" },
                        { label: "Website", href: "https://www.childline.ie/" }
                    ]
                },
                {
                    title: "LGBT Ireland",
                    subtitle: "Helpline support (check opening hours)",
                    links: [
                        { label: "Call 1800 929 539", href: "tel:1800929539" },
                        { label: "Contact", href: "https://lgbt.ie/contact-us/" },
                        { label: "Opening hours", href: "https://lgbt.ie/lgbt-helpline-opening-hours/" }
                    ]
                },
                {
                    title: "Women's Aid",
                    subtitle: "Domestic abuse support, available 24/7",
                    links: [
                        { label: "Call 1800 341 900", href: "tel:1800341900" },
                        { label: "Website", href: "https://www.womensaid.ie/about-us/contact-us/" }
                    ]
                },
                {
                    title: "Men's Aid Ireland",
                    subtitle: "Domestic abuse support for men",
                    links: [
                        { label: "Call 01 554 3811", href: "tel:015543811" },
                        { label: "Website", href: "https://www.mensaid.ie/" }
                    ]
                },
                {
                    title: "Dublin Rape Crisis Centre",
                    subtitle: "Sexual violence, national 24-hour helpline",
                    links: [
                        { label: "Call 1800 77 8888", href: "tel:1800778888" },
                        { label: "Helpline info", href: "https://www.drcc.ie/services/helpline/" }
                    ]
                },
                {
                    title: "ALONE",
                    subtitle: "Loneliness and older people support line",
                    links: [
                        { label: "Call 0818 222 024", href: "tel:0818222024" },
                        { label: "Website", href: "https://alone.ie/contact/" }
                    ]
                },
                {
                    title: "SOSAD",
                    subtitle: "24-hour support helpline",
                    links: [
                        { label: "Call 1800 901 909", href: "tel:1800901909" },
                        { label: "Website", href: "https://sosadireland.ie/contact-sosad-ireland-ie/" }
                    ]
                }
            ]

            dublin_support = [
                {
                    title: "MyMind",
                    subtitle: "Counselling and psychotherapy (Rathmines HQ)",
                    address: "137 Rathmines Road Lower, Dublin 6 (D06 V3Y8)",
                    links: [
                        { label: "Call 0818 500 800", href: "tel:0818500800" },
                        { label: "Location", href: "https://users.mymind.org/location/dublin-6" }
                    ]
                },
                {
                    title: "Jigsaw Dublin City",
                    subtitle: "Free youth mental-health support (ages 12-25)",
                    links: [
                        { label: "Call (01) 658 3070", href: "tel:016583070" },
                        { label: "Location", href: "https://jigsaw.ie/location/dublin-city/" }
                    ]
                },
                {
                    title: "Jigsaw Dublin South West",
                    subtitle: "Free youth mental-health support (ages 12-25)",
                    links: [
                        { label: "Call 01 538 0087", href: "tel:015380087" },
                        { label: "Location", href: "https://jigsaw.ie/location/dublin-south-west/" }
                    ]
                },
                {
                    title: "Dublin Rape Crisis Centre",
                    subtitle: "In-person service in Dublin 2",
                    address: "McGonnell House, 70 Lower Leeson Street, Dublin 2",
                    links: [
                        { label: "Call 1800 77 8888", href: "tel:1800778888" },
                        { label: "Contact details", href: "https://www.drcc.ie/about/contact/" }
                    ]
                }
            ]
        %>
        <div class="alert-help-card__inner">
            <h2>Mental health support in Ireland (and Dublin)</h2>
            <p>
                If you or someone else is in <strong>immediate danger</strong>,
                call
                <a href="tel:999"><strong>999</strong></a>
                /
                <a href="tel:112"><strong>112</strong></a>
                or go to the nearest <strong>A&amp;E</strong>.
            </p>
            <p>
                More info:
                <a href="https://www.mhcirl.ie/help-and-advice/urgent-help-and-support">mhcirl.ie urgent help</a>
                and
                <a href="https://www2.hse.ie/mental-health/services-support/get-urgent-help/">HSE urgent help</a>.
            </p>

            <section class="alert-help-group">
                <h3>Ireland-wide crisis support</h3>
                <div class="alert-help-grid">
                    <% crisis_support.each do |service| %>
                        <article class="alert-help-item">
                            <h4><%= service[:title] %></h4>
                            <p class="alert-help-item__subtitle"><%= service[:subtitle] %></p>
                            <div class="alert-help-item__actions">
                                <% service[:links].each do |link| %>
                                    <a href="<%= link[:href] %>" class="alert-help-pill"><%= link[:label] %></a>
                                <% end %>
                            </div>
                        </article>
                    <% end %>
                </div>
            </section>

            <section class="alert-help-group">
                <h3>Ireland-wide support (non-emergency)</h3>
                <div class="alert-help-grid">
                    <% non_emergency_support.each do |service| %>
                        <article class="alert-help-item">
                            <h4><%= service[:title] %></h4>
                            <p class="alert-help-item__subtitle"><%= service[:subtitle] %></p>
                            <div class="alert-help-item__actions">
                                <% service[:links].each do |link| %>
                                    <a href="<%= link[:href] %>" class="alert-help-pill"><%= link[:label] %></a>
                                <% end %>
                            </div>
                        </article>
                    <% end %>
                </div>
            </section>

            <section class="alert-help-group">
                <h3>Dublin-specific services</h3>
                <div class="alert-help-grid">
                    <% dublin_support.each do |service| %>
                        <article class="alert-help-item">
                            <h4><%= service[:title] %></h4>
                            <p class="alert-help-item__subtitle"><%= service[:subtitle] %></p>
                            <% if service[:address].present? %>
                                <p class="alert-help-item__address"><%= service[:address] %></p>
                            <% end %>
                            <div class="alert-help-item__actions">
                                <% service[:links].each do |link| %>
                                    <a href="<%= link[:href] %>" class="alert-help-pill"><%= link[:label] %></a>
                                <% end %>
                            </div>
                        </article>
                    <% end %>
                </div>
            </section>
        </div>
    </section>
</main>
