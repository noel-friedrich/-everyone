<% content_for :title, "everyone" %>

<canvas
    id="flow-canvas"
    class="flow-canvas"
    data-controller="flow"
    aria-hidden="true"
></canvas>

<a href="/" class="logo-container" aria-label="@everyone home">
    <%= image_tag "logo-with-text.png", alt: "@everyone logo", class: "logo" %>
</a>

<main class="landing">
    <section class="landing__content">
        <h1>Reach your trusted people faster.</h1>
        <p>
            Set up a one-tap call button for your inner circle. Everyone gets
            called at the same time, and the first person to answer is connected
            to you instantly. No app needed for them. Built for the moments you
            need it most.
        </p>
        <a href="/studio" class="landing__cta"> Set up your circle </a>
    </section>

    <section class="landing-sections" aria-label="More information">
        <article class="landing-card">
            <h2>FAQ</h2>
            <div class="landing-faq">
                <div class="landing-faq__item">
                    <h3>How fast does a call alert go out?</h3>
                    <p>
                        As soon as you trigger an alert, your confirmed contacts
                        are called in parallel.
                    </p>
                </div>
                <div class="landing-faq__item">
                    <h3>Do my contacts need to install anything?</h3>
                    <p>
                        No. They only need a phone that can receive calls and
                        SMS.
                    </p>
                </div>
                <div class="landing-faq__item">
                    <h3>Can someone opt out later?</h3>
                    <p>
                        Yes. Consent is managed per contact, and declined
                        contacts are not alerted.
                    </p>
                </div>
            </div>
        </article>

        <article class="landing-card">
            <h2>Contact us</h2>
            <p>
                Questions, feedback, or partnerships. Send us a message and we
                will get back to you.
            </p>
            <form class="landing-contact-form" action="#" method="post">
                <label for="contact-email">Email</label>
                <input
                    id="contact-email"
                    name="email"
                    type="email"
                    placeholder="you@example.com"
                    required
                />

                <label for="contact-message">Message</label>
                <textarea
                    id="contact-message"
                    name="message"
                    rows="4"
                    placeholder="How can we help?"
                ></textarea>

                <button type="submit" class="landing-contact-form__submit">
                    Send message
                </button>
            </form>
        </article>
    </section>
</main>
