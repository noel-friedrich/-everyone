<% content_for :title, "studio" %>

<canvas
    id="flow-canvas"
    class="flow-canvas"
    data-controller="flow"
    aria-hidden="true"
></canvas>

<a href="/" class="logo-container" aria-label="@everyone home">
    <%= image_tag "logo-with-text.png", alt: "@everyone logo", class: "logo logo--studio" %>
</a>

<main class="studio-page">
    <section class="studio-top">
        <h1>Contact Studio</h1>
        <p>Manage the people who will be contacted when you trigger an alert.</p>
        <div class="studio-alert-row" role="group" aria-label="Alert actions">
            <button type="button" class="studio-alert-chip is-primary">
                ALERT
            </button>
            <button type="button" class="studio-alert-chip">Soft Alert</button>
            <button type="button" class="studio-alert-chip">
                Alert Settings
            </button>
            <button type="button" class="studio-alert-chip">
                Test Contacts
            </button>
        </div>
    </section>

    <section class="studio-table-shell">
        <div class="studio-table-head">
            <h2>Your contacts</h2>
            <button type="button" class="studio-add">Add another contact</button>
        </div>

        <div class="studio-table-wrap">
            <table class="studio-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Phone</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% @contacts.each do |contact| %>
                    <tr>
                        <td><%= contact[:name] %></td>
                        <td><%= contact[:phone] %></td>
                        <td>
                            <span
                                class="studio-status <%= contact[:confirmed] ? 'is-confirmed' : 'is-pending' %>"
                            >
                                <%= contact[:confirmed] ? "Confirmed" : "Pending" %>
                            </span>
                        </td>
                        <td>
                            <div class="studio-actions">
                                <button type="button" class="studio-action-btn">
                                    Edit
                                </button>
                                <button
                                    type="button"
                                    class="studio-action-btn is-danger"
                                >
                                    Remove
                                </button>
                            </div>
                        </td>
                    </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
    </section>
</main>
